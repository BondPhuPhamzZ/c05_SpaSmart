@page
@model c05_SpaSmart.Pages.DanhMucDichVu.EditModel
@{
    ViewData["Title"] = "Sửa Danh Mục";
}

<div class="container-fluid">
    <h1 class="h3 mb-2 text-gray-800">Chỉnh sửa Danh Mục</h1>
    <div class="card shadow mb-4">
        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="DanhMuc.Id" />
                <div class="form-group">
                    <label asp-for="DanhMuc.TenDanhMuc" class="control-label"></label>
                    <input asp-for="DanhMuc.TenDanhMuc" class="form-control" />
                    <span asp-validation-for="DanhMuc.TenDanhMuc" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DanhMuc.MoTa" class="control-label"></label>
                    <input asp-for="DanhMuc.MoTa" class="form-control" />
                    <span asp-validation-for="DanhMuc.MoTa" class="text-danger"></span>
                </div>
                <div class="form-group mt-3">
                    <input type="submit" value="Cập nhật" class="btn btn-primary" />
                    <a asp-page="./Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
