@page
@model c05_SpaSmart.Pages.DanhMucDichVu.IndexModel
@{
    ViewData["Title"] = "Quản lý Danh Mục";
}

<div class="container-fluid">
    <h1 class="h3 mb-2 text-gray-800">Quản lý Danh Mục</h1>
    <p class="mb-4">Phân hệ quản lý danh mục dịch vụ và phụ liệu (Thịnh đảm nhận).</p>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách Danh Mục</h6>
            <a asp-page="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Thêm mới</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên Danh Mục</th>
                            <th>Mô Tả</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DanhMucDichVus)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.TenDanhMuc</td>
                                <td>@item.MoTa</td>
                                <td>
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display:inline;">
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa?');"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
