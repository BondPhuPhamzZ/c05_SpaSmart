@page
@model c05_SpaSmart.Pages.PhieuChi.IndexModel
@{
    ViewData["Title"] = "Lịch sử Phiếu Chi";
}

<div class="container-fluid">
    <h1 class="h3 mb-2 text-gray-800">Quản lý Phiếu Chi</h1>
    <p class="mb-4">Phân hệ theo dõi chi phí.</p>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách Phiếu Chi</h6>
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createModal"><i class="fas fa-plus"></i> Tạo Phiếu Chi Mới</button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Ngày Chi</th>
                            <th>Lý do</th>
                            <th>Người Chi</th>
                            <th>Số Tiền (VNĐ)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PhieuChis)
                        {
                            <tr>
                                <td>@item.NgayChi.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.LyDoChi</td>
                                <td>@item.NguoiChi</td>
                                <td class="text-danger font-weight-bold">-@item.SoTien.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius: 0;">
            <div class="modal-header">
                <h5 class="modal-title">Tạo Phiếu Chi Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div class="form-group">
                        <label>Lý do chi</label>
                        <textarea name="LyDoChi" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>Người thực hiện</label>
                            <input name="NguoiChi" class="form-control" required />
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Số Tiền (VNĐ)</label>
                            <input name="SoTien" class="form-control" type="number" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-danger">Lưu Phiếu Chi</button>
                </div>
            </form>
        </div>
    </div>
</div>
