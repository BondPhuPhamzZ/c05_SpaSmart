@page
@model c05_SpaSmart.Pages.ThongKe.IndexModel
@{
    ViewData["Title"] = "Thống Kê Doanh Thu";
}

<div class="container-fluid">
    <h1 class="h3 mb-2 text-gray-800">Thống Kê Doanh Thu & Chi Phí</h1>
    <p class="mb-4">Báo cáo tổng hợp tình hình kinh doanh.</p>

    <div class="row">
        <!-- Tổng Doanh Thu (Hóa Đơn) -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Tổng Doanh Thu (Phiếu Tính Tiền)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TongDoanhThu.ToString("N0") VNĐ</div>
                        </div>
                        <div class="col-auto">
                            <div class="icon-circle">
                                <i class="fas fa-dollar-sign"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tổng Chi Phí (Phiếu Chi) -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                Tổng Chi Phí (Phiếu Chi)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TongChiPhi.ToString("N0") VNĐ</div>
                        </div>
                        <div class="col-auto">
                            <div class="icon-circle">
                                <i class="fas fa-file-invoice-dollar"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lợi Nhuận -->
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Lợi Nhuận Tạm Tính</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.LoiNhuan.ToString("N0") VNĐ</div>
                        </div>
                        <div class="col-auto">
                            <div class="icon-circle">
                                <i class="fas fa-wallet"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
