@page
@model c05_SpaSmart.Pages.DichVu.IndexModel
@{
    ViewData["Title"] = "Qu?n lý D?ch v? / Ph? li?u";
}

<div class="container-fluid">
    <h1 class="h3 mb-2 text-gray-800">Qu?n lý S?n ph?m / D?ch v?</h1>
    <p class="mb-4">Phân h? qu?n lý toŕn b? D?ch v? vŕ Ph? li?u (Phú d?m nh?n).</p>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách S?n ph?m / D?ch v?</h6>
            <a asp-page="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Thęm m?i</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Tęn</th>
                            <th>Lo?i</th>
                            <th>Danh M?c</th>
                            <th>Giá (VNĐ)</th>
                            <th>Gi?m Giá</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DichVus)
                        {
                            <tr>
                                <td>@item.TenDichVu</td>
                                <td>
                                    @if(item.Loai == 1) { <span class="badge badge-success">D?ch v?</span> }
                                    else { <span class="badge badge-info">Ph? li?u</span> }
                                </td>
                                <td>@(item.DanhMuc?.TenDanhMuc ?? "")</td>
                                <td>@item.GiaTien.ToString("N0")</td>
                                <td>@item.GiamGia.ToString("N0")</td>
                                <td>
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" style="display:inline;">
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Xác nh?n xóa?');"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
