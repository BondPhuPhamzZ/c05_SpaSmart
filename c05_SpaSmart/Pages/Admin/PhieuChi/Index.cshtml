@page
@model c05_SpaSmart.Pages.Admin.PhieuChi.IndexModel

@{
    ViewData["Title"] = "Quản lý Chi Tiêu";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Phiếu Chi</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-page="Create" class="btn btn-sm btn-danger">
            + Lập Phiếu Chi Mới
        </a>
    </div>
</div>

<div class="alert alert-warning">
    <strong>Tổng chi tiêu vận hành: </strong> @Model.TongChiTieu.ToString("N0") VNĐ
</div>

<div class="table-responsive">
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>Mã Phiếu</th>
                <th>Ngày Chi</th>
                <th>Số Tiền Chi</th>
                <th>Lý Do Chi (Điện, Nước, Phụ liệu)</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model.PhieuChiList) {
            <tr>
                <td>#@item.Id</td>
                <td>@item.NgayLap.ToString("dd/MM/yyyy HH:mm")</td>
                <td class="text-danger fw-bold">- @item.SoTien.ToString("N0") VNĐ</td>
                <td>@item.LyDoChi</td>
            </tr>
}
        </tbody>
    </table>
</div>
