@page
@model c05_SpaSmart.Pages.Admin.KyThuatVien.IndexModel

@{
    ViewData["Title"] = "Quản lý Kỹ Thuật Viên";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Kỹ Thuật Viên</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-page="Create" class="btn btn-sm btn-primary">
            + Thêm KTV Mới
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>Mã NV</th>
                <th>Họ Tên</th>
                <th>Chuyên Môn</th>
                <th>Trạng Thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model.KyThuatVienList) {
            <tr>
                <td>#@item.Id</td>
                <td>@Html.DisplayFor(modelItem => item.HoTen)</td>
                <td>@Html.DisplayFor(modelItem => item.ChuyenMon)</td>
                <td>
                    @if(item.TrangThaiKTV == c05_SpaSmart.Models.Enums.TrangThaiKTV.SanSang)
                    {
                        <span class="badge bg-success">Sẵn sàng</span>
                    }
                    else if(item.TrangThaiKTV == c05_SpaSmart.Models.Enums.TrangThaiKTV.DangBan)
                    {
                        <span class="badge bg-warning text-dark">Đang bận</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Nghỉ phép</span>
                    }
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
