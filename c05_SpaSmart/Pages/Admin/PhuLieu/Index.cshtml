@page
@model c05_SpaSmart.Pages.Admin.PhuLieu.IndexModel

@{
    ViewData["Title"] = "Quản lý Phụ Liệu";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Phụ Liệu Kho</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-page="Create" class="btn btn-sm btn-primary">
            + Nhập Phụ Liệu
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tên Phụ Liệu</th>
                <th>Tồn Kho</th>
                <th>Đơn Vị Tính</th>
                <th>Giá Mua Gần Nhất</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model.PhuLieuList) {
            <tr>
                <td>#@item.Id</td>
                <td>@item.TenPhuLieu</td>
                <td>
                    @if(item.TonKho < 10) {
                        <span class="text-danger fw-bold">@item.TonKho (Sắp hết)</span>
                    } else {
                        @item.TonKho
                    }
                </td>
                <td>@item.DonGia.ToString("N0") VNĐ</td>
            </tr>
}
        </tbody>
    </table>
</div>
