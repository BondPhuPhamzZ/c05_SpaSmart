@page
@model c05_SpaSmart.Pages.Admin.PhuLieu.IndexModel
@{
    ViewData["Title"] = "Quản lý Phụ Liệu / Kho";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0 fw-bold text-dark">Danh sách phụ liệu</h5>
        <div>
            <a asp-page="/Admin/DanhMucPhuLieu/Create" class="btn btn-outline-primary rounded-pill me-2">Gắn định mức</a>
            <a asp-page="./Create" class="btn btn-primary rounded-pill"><i class="fas fa-plus me-1"></i> Nhập phụ liệu mới</a>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle text-center mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-start">Tên Phụ Liệu</th>
                        <th>Hãng Sản Xuất</th>
                        <th>Đơn Giá / Đơn Vị</th>
                        <th>Tồn Kho Hiện Tại</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.PhuLieuList) {
                        <tr>
                            <td class="px-4 fw-medium text-dark text-start">@item.TenPhuLieu</td>
                            <td>@item.HangSanXuat</td>
                            <td class="text-primary-teal fw-bold">@item.DonGia.ToString("N0")đ</td>
                            <td>
                                @if (item.TonKho <= 10)
                                {
                                    <span class="badge bg-danger fs-6">@item.TonKho (Sắp hết)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success fs-6">@item.TonKho</span>
                                }
                            </td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-circle me-1" title="Cập nhật">Cập nhật</a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa phụ liệu này?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" title="Xóa">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
