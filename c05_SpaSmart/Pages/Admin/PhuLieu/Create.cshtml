@page
@model c05_SpaSmart.Pages.Admin.PhuLieu.CreateModel

@{
    ViewData["Title"] = "Nhập Phụ Liệu";
}

<h2>Nhập Phụ Liệu Mới</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="PhuLieu.TenPhuLieu" class="form-label">Tên phụ liệu (Tinh dầu, khăn...)</label>
                <input asp-for="PhuLieu.TenPhuLieu" class="form-control" />
                <span asp-validation-for="PhuLieu.TenPhuLieu" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PhuLieu.TonKho" class="form-label">Số lượng nhập</label>
                <input asp-for="PhuLieu.TonKho" type="number" class="form-control" />
                <span asp-validation-for="PhuLieu.TonKho" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PhuLieu.DonGia" class="form-label">Giá mua (VNĐ)</label>
                <input asp-for="PhuLieu.DonGia" type="number" class="form-control" />
                <span asp-validation-for="PhuLieu.DonGia" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <input type="submit" value="Lưu Dữ Liệu Kho" class="btn btn-primary" />
                <a asp-page="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
