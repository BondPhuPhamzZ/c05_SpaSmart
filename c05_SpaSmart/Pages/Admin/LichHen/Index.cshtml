@page
@using c05_SpaSmart.Models.Enums
@model c05_SpaSmart.Pages.Admin.LichHen.IndexModel
@{
    ViewData["Title"] = "Quản lý Lịch Hẹn & Điều Phối";
}

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold text-dark">Danh sách lịch hẹn</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle text-center mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3 text-start">Mã Lịch</th>
                        <th>Khách Hàng</th>
                        <th>Thời Gian Khách Đến</th>
                        <th>Kỹ Thuật Viên</th>
                        <th>Trạng Thái</th>
                        <th>Tổng Tiền</th>
                        <th>Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LichHenList) {
                        <tr>
                            <td class="px-4 fw-medium text-dark text-start">#@item.Id</td>
                            <td>
                                <div>@item.User?.FullName</div>
                                <small class="text-muted">@item.User?.PhoneNumber</small>
                            </td>
                            <td>
                                <div>@item.NgayGioDat.ToString("dd/MM/yyyy")</div>
                                <div class="fw-bold text-primary-teal">@item.NgayGioDat.ToString("HH:mm")</div>
                            </td>
                            <td>
                                @if(item.KyThuatVien != null)
                                {
                                    @item.KyThuatVien.HoTen
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Random</span>
                                }
                            </td>
                            <td>
                                @if (item.TrangThai == TrangThaiLichHen.ChoXacNhan)
                                {
                                    <span class="badge bg-warning text-dark">Chờ Xác Nhận</span>
                                }
                                else if (item.TrangThai == TrangThaiLichHen.DaXacNhan)
                                {
                                    <span class="badge bg-info text-dark">Đã Xác Nhận</span>
                                }
                                else if (item.TrangThai == TrangThaiLichHen.DangPhucVu)
                                {
                                    <span class="badge bg-primary">Đang Phục Vụ</span>
                                }
                                else if (item.TrangThai == TrangThaiLichHen.DaPhucVuXong)
                                {
                                    <span class="badge bg-secondary">Chờ Thanh Toán</span>
                                }
                                else if (item.TrangThai == TrangThaiLichHen.DaThanhToan)
                                {
                                    <span class="badge bg-success">Đã Hoàn Tất</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã Hủy</span>
                                }
                            </td>
                            <td class="fw-bold text-danger">@item.TongTien.ToString("N0")đ</td>
                            <td>
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill">Xử lý</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
