@page
@model c05_SpaSmart.Pages.Admin.LichHen.IndexModel
@using c05_SpaSmart.Models.Enums

@{
    ViewData["Title"] = "Quản lý Lịch Hẹn";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Lịch Hẹn</h1>
</div>

<div class="table-responsive">
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>Mã</th>
                <th>Khách hàng</th>
                <th>Ngày hẹn</th>
                <th>Dịch Vụ</th>
                <th>KTV Phụ trách</th>
                <th>Tổng Tiền</th>
                <th>Trạng Thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model.LichHenList) {
            <tr>
                <td>#@item.Id</td>
                <td>@item.User?.Username</td>
                <td>@item.NgayGioDat.ToString("dd/MM/yyyy HH:mm")</td>
                <td>
                    @foreach (var chiTiet in item.ChiTietLichHens)
                    {
                        <div>- @chiTiet.GoiDichVu.TenDichVu</div>
                    }
                </td>
                <td>@(item.KyThuatVien?.HoTen ?? "Chưa xếp")</td>
                <td>@item.TongTien.ToString("N0") VNĐ</td>
                <td>
                    @if(item.TrangThai == TrangThaiLichHen.ChoXacNhan)
                    {
                        <span class="badge bg-warning text-dark">Chờ XN</span>
                    }
                    else if(item.TrangThai == TrangThaiLichHen.DaXacNhan)
                    {
                        <span class="badge bg-info text-dark">Đã XN</span>
                    }
                    else if(item.TrangThai == TrangThaiLichHen.DangPhucVu)
                    {
                        <span class="badge bg-primary">Đang PV</span>
                    }
                    else if(item.TrangThai == TrangThaiLichHen.DaPhucVuXong)
                    {
                        <span class="badge bg-secondary">Xong - Chờ TT</span>
                    }
                    else if(item.TrangThai == TrangThaiLichHen.DaThanhToan)
                    {
                        <span class="badge bg-success">Hoàn thành</span>
                    }
                    else
                    {
                         <span class="badge bg-danger">Hủy</span>
                    }
                </td>
                <td>
                    <form method="post" class="d-inline d-flex gap-2">
                        <input type="hidden" name="id" value="@item.Id" />
                        
                        @if (item.TrangThai == TrangThaiLichHen.ChoXacNhan)
                        {
                            <select name="ktvId" class="form-select form-select-sm" style="width: auto;">
                                <option value="">-- Chọn KTV rảnh --</option>
                                @foreach(var ktv in Model.KtvSanSangList)
                                {
                                    <option value="@ktv.Id">@ktv.HoTen</option>
                                }
                            </select>
                            <button type="submit" asp-page-handler="UpdateStatus" asp-route-status="@((int)TrangThaiLichHen.DaXacNhan)" class="btn btn-sm btn-info text-nowrap">Duyệt lịch</button>
                        }
                        else if (item.TrangThai == TrangThaiLichHen.DaXacNhan)
                        {
                            <button type="submit" asp-page-handler="UpdateStatus" asp-route-status="@((int)TrangThaiLichHen.DangPhucVu)" class="btn btn-sm btn-primary text-nowrap">Bắt đầu Phục vụ</button>
                        }
                        else if (item.TrangThai == TrangThaiLichHen.DangPhucVu)
                        {
                            <button type="submit" asp-page-handler="UpdateStatus" asp-route-status="@((int)TrangThaiLichHen.DaPhucVuXong)" class="btn btn-sm btn-secondary text-nowrap">Đã Phục vụ xong</button>
                        }
                        else if (item.TrangThai == TrangThaiLichHen.DaPhucVuXong)
                        {
                            <a asp-page="./ThanhToan" asp-route-id="@item.Id" class="btn btn-sm btn-success fw-bold text-nowrap">Thanh Toán</a>
                        }
                    </form>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
