@page
@model c05_SpaSmart.Pages.Admin.GoiDichVu.EditModel
@{
    ViewData["Title"] = "Cập Nhật Dịch Vụ";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-dark">Cập nhật thông tin dịch vụ</h5>
            </div>
            <div class="card-body p-4">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="GoiDichVu.Id" />
                    <div class="mb-3">
                        <label asp-for="GoiDichVu.TenDichVu" class="form-label fw-bold">Tên Dịch Vụ <span class="text-danger">*</span></label>
                        <input asp-for="GoiDichVu.TenDichVu" class="form-control form-control-lg" />
                        <span asp-validation-for="GoiDichVu.TenDichVu" class="text-danger small"></span>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="GoiDichVu.GiaTien" class="form-label fw-bold">Giá Tiền (VNĐ) <span class="text-danger">*</span></label>
                            <input asp-for="GoiDichVu.GiaTien" type="number" step="1000" class="form-control form-control-lg" />
                            <span asp-validation-for="GoiDichVu.GiaTien" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GoiDichVu.ThoiLuongPhut" class="form-label fw-bold">Thời Lượng (Phút) <span class="text-danger">*</span></label>
                            <input asp-for="GoiDichVu.ThoiLuongPhut" type="number" class="form-control form-control-lg" />
                            <span asp-validation-for="GoiDichVu.ThoiLuongPhut" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label asp-for="GoiDichVu.MoTa" class="form-label fw-bold">Mô Tả Chi Tiết</label>
                        <textarea asp-for="GoiDichVu.MoTa" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="GoiDichVu.MoTa" class="text-danger small"></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-page="./Index" class="btn btn-outline-secondary px-4 rounded-pill">Quay lại</a>
                        <button type="submit" class="btn btn-primary px-5 rounded-pill">Lưu Cập Nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
