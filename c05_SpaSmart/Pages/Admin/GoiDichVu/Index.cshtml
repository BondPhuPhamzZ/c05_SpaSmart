@page
@model c05_SpaSmart.Pages.Admin.GoiDichVu.IndexModel

@{
    ViewData["Title"] = "Quản lý Gói Dịch Vụ";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Quản lý Gói Dịch Vụ</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-page="Create" class="btn btn-sm btn-primary">
            + Thêm Gói Mới
        </a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>#</th>
                <th>Tên Dịch Vụ</th>
                <th>Mô Tả</th>
                <th>Giá Tiền</th>
                <th>Thời Lượng (Phút)</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model.GoiDichVuList) {
            <tr>
                <td>@item.Id</td>
                <td>@Html.DisplayFor(modelItem => item.TenDichVu)</td>
                <td>@Html.DisplayFor(modelItem => item.MoTa)</td>
                <td>@item.GiaTien.ToString("N0") VNĐ</td>
                <td>@item.ThoiLuongPhut</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>
