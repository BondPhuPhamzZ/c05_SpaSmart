@page
@model c05_SpaSmart.Pages.PhieuTinhTien.IndexModel
@{
    ViewData["Title"] = "Quản lý Hóa Đơn (Tính Tiền)";
}

<div class="container-fluid">
    <h1 class="h3 mb-2 text-gray-800">Quản lý Phiếu Tính Tiền</h1>
    <p class="mb-4">Phân hệ Tính tiền và Lịch sử hóa đơn (Viên đảm nhận).</p>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Danh sách Hóa Đơn</h6>
            <a asp-page="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Tạo Hóa Đơn Mới (Tính Tiền)</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Khách Hàng</th>
                            <th>SĐT</th>
                            <th>Ngày TT</th>
                            <th>Tổng Tiền (VNĐ)</th>
                            <th>Trạng Thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.PhieuTinhTiens)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.TenKhachHang</td>
                                <td>@item.SoDienThoai</td>
                                <td>@item.NgayThanhToan.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.TongTien.ToString("N0")</td>
                                <td><span class="text-success font-weight-bold">@item.TrangThai</span></td>
                                <td>
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-info btn-sm"><i class="fas fa-eye"></i> Chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
