@page
@model c05_SpaSmart.Pages.PhieuTinhTien.CreateModel
@{
    ViewData["Title"] = "Tạo Hóa Đơn";
}

<div class="container-fluid">
    <h1 class="h3 mb-2 text-gray-800">Lập Phiếu Tính Tiền (POS)</h1>
    <div class="card shadow mb-4" style="border-radius: 0;">
        <div class="card-body">
            <form method="post">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label asp-for="PhieuTinhTien.TenKhachHang" class="control-label">Tên Khách Hàng</label>
                        <input asp-for="PhieuTinhTien.TenKhachHang" class="form-control" />
                        <span asp-validation-for="PhieuTinhTien.TenKhachHang" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 form-group">
                        <label asp-for="PhieuTinhTien.SoDienThoai" class="control-label">Số Điện Thoại</label>
                        <input asp-for="PhieuTinhTien.SoDienThoai" class="form-control" />
                        <span asp-validation-for="PhieuTinhTien.SoDienThoai" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 form-group">
                        <label asp-for="PhieuTinhTien.TenKtv" class="control-label">Tên KTV</label>
                        <input asp-for="PhieuTinhTien.TenKtv" class="form-control" />
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label asp-for="PhieuTinhTien.HinhThucThanhToan" class="control-label">Hình thức TT</label>
                        <select asp-for="PhieuTinhTien.HinhThucThanhToan" class="form-control">
                            <option value="Tiền mặt">Tiền mặt</option>
                            <option value="Chuyển khoản">Chuyển khoản</option>
                        </select>
                    </div>
                    <div class="col-md-4 form-group">
                        <label asp-for="PhieuTinhTien.TongTien" class="control-label">Tổng tiền (VNĐ)</label>
                        <input asp-for="PhieuTinhTien.TongTien" class="form-control" type="number" />
                    </div>
                </div>
                
                <div class="form-group mt-3">
                    <input type="submit" value="Thanh toán & Lưu" class="btn btn-success" />
                    <a asp-page="Index" class="btn btn-secondary">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
