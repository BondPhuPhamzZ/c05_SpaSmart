@model IEnumerable<c05_SpaSmart.Models.GoiDichVu>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold text-primary-teal mb-3">Chào mừng đến với SpaSmart</h1>
    <p class="lead text-muted">Trải nghiệm dịch vụ chăm sóc sức khỏe và làm đẹp hàng đầu.</p>
    @if (!User.Identity!.IsAuthenticated)
    {
        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-lg rounded-pill px-5 mt-3 shadow">Đăng ký thành viên ngay</a>
    }
</div>

<h2 class="fw-bold mb-4 text-center">Các gói dịch vụ nổi bật</h2>
<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4">
            <partial name="_ServiceCardPartial" model="item" />
        </div>
    }
</div>
