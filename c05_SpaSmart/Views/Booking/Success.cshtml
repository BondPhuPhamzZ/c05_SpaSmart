@{
    ViewData["Title"] = "Đặt lịch thành công";
}

<div class="text-center mt-5">
    <div class="display-1 text-success mb-3">
        <i class="bi bi-check-circle-fill">✓</i>
    </div>
    <h2 class="text-success">Đặt Lịch Thành Công!</h2>
    <p class="lead mt-3">Mã lịch hẹn của bạn là: <strong>#@ViewBag.LichHenId</strong></p>
    <p>Trạng thái hiện tại: <strong>Chờ Xác Nhận</strong>. Lễ tân SpaSmart sẽ sớm kiểm tra lịch và duyệt trên hệ thống.</p>
    
    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Về Trang Chủ</a>
    </div>
</div>
