@model c05_SpaSmart.Models.ViewModels.BookingViewModel

@{
    ViewData["Title"] = "Đặt lịch hẹn";
    var services = ViewBag.Services as List<c05_SpaSmart.Models.GoiDichVu>;
    var ktvs = ViewBag.KTVs as List<c05_SpaSmart.Models.KyThuatVien>;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                <h3 class="fw-bold text-primary-teal text-center"><i class="far fa-calendar-check me-2"></i> Đặt Lịch Hẹn Trực Tuyến</h3>
                <p class="text-center text-muted mb-0">Vui lòng chọn dịch vụ và thời gian bạn mong muốn</p>
            </div>
            <div class="card-body p-4 p-md-5 pt-4">
                <form asp-controller="Booking" asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 p-3 bg-danger bg-opacity-10 rounded"></div>

                    <h5 class="fw-bold mb-3 border-bottom pb-2">1. Thông tin thời gian</h5>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="NgayGioDat" class="form-label fw-medium">Ngày & Giờ đến <span class="text-danger">*</span></label>
                                <input asp-for="NgayGioDat" class="form-control" type="datetime-local" />
                                <span asp-validation-for="NgayGioDat" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="KyThuatVienId" class="form-label fw-medium">Kỹ thuật viên yêu thích</label>
                                <select asp-for="KyThuatVienId" class="form-select">
                                    <option value="">-- Bất kỳ ai (Spa tự xếp) --</option>
                                    @if(ktvs != null)
                                    {
                                        foreach(var ktv in ktvs)
                                        {
                                            <option value="@ktv.Id">@ktv.HoTen (@ktv.ChuyenMon)</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="KyThuatVienId" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 border-bottom pb-2">2. Dịch vụ lựa chọn <span class="text-danger">*</span></h5>
                    <span asp-validation-for="DichVuIds" class="text-danger small d-block mb-2"></span>
                    <div class="row mb-4 g-3">
                        @if(services != null)
                        {
                            foreach(var svc in services)
                            {
                                <div class="col-md-6">
                                    <div class="form-check custom-checkbox card p-3 h-100 shadow-sm border-0 bg-light">
                                        <input class="form-check-input ms-0 me-2 mt-1" type="checkbox" name="DichVuIds" value="@svc.Id" id="svc_@svc.Id" style="transform: scale(1.2);">
                                        <label class="form-check-label w-100" for="svc_@svc.Id">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <span class="fw-bold text-dark">@svc.TenDichVu</span>
                                                <span class="badge bg-primary text-white">@svc.ThoiLuongPhut p</span>
                                            </div>
                                            <div class="text-danger fw-bold mt-1">@svc.GiaTien.ToString("N0")đ</div>
                                        </label>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <h5 class="fw-bold mb-3 border-bottom pb-2">3. Lời nhắn</h5>
                    <div class="form-group mb-4">
                        <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Ví dụ: Vui lòng massage nhẹ tay..."></textarea>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow">Xác Nhận Đặt Lịch</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
