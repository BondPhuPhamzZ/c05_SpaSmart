@model IEnumerable<c05_SpaSmart.Models.GoiDichVu>

@{
    ViewData["Title"] = "Dịch Vụ SpaSmart";
}

<h2 class="mt-4 mb-4">Các gói dịch vụ hiện có</h2>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-primary">@item.TenDichVu</h5>
                    <p class="card-text">@item.MoTa</p>
                    <ul class="list-unstyled">
                        <li><strong>Giá: </strong>@item.GiaTien.ToString("N0") VNĐ</li>
                        <li><strong>Thời lượng: </strong>@item.ThoiLuongPhut phút</li>
                    </ul>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-3">
                    <a asp-action="Create" asp-route-dichVuId="@item.Id" class="btn btn-success w-100">Đặt Lịch Ngay</a>
                </div>
            </div>
        </div>
    }
</div>
