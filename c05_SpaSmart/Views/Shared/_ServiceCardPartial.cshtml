@model c05_SpaSmart.Models.GoiDichVu

<div class="card h-100 border-0 shadow-sm">
    <div class="card-body p-4 text-center">
        <div class="display-1 text-primary-teal mb-3"><i class="fas fa-spa"></i></div>
        <h4 class="card-title fw-bold">@Model.TenDichVu</h4>
        <p class="card-text text-muted mb-4">@Model.MoTa</p>
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <span class="fs-5 fw-bold text-danger">@Model.GiaTien.ToString("N0")đ</span>
            <span class="badge bg-primary text-white"><i class="far fa-clock me-1"></i> @Model.ThoiLuongPhut phút</span>
        </div>
    </div>
    <div class="card-footer bg-white border-0 p-4 pt-0">
        <a asp-controller="Booking" asp-action="Create" class="btn btn-outline-primary w-100 rounded-pill fw-bold">Đặt lịch dịch vụ này</a>
    </div>
</div>
